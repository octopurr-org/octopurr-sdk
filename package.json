{
  "name": "@octopurr/sdk",
  "version": "1.1.0",
  "description": "Octopurr SDK — TypeScript SDK for PancakeSwap V3 Token Launchpad on BSC",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "viem": "^2.46.2"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/octopurr-org/octopurr-sdk.git"
  },
  "keywords": ["octopurr", "pancakeswap", "bsc", "defi", "token-launchpad", "sdk"]
}
